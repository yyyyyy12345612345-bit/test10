# NOIR LABEL — Environment Variables

# ================================
# DATABASE (Supabase + Prisma)
# ================================
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ================================
# SUPABASE
# ================================
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON_KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"

# ================================
# AUTHENTICATION (Better Auth)
# ================================
BETTER_AUTH_SECRET="[GENERATE: openssl rand -base64 32]"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="[FROM Google Cloud Console]"
GOOGLE_CLIENT_SECRET="[FROM Google Cloud Console]"

# Apple OAuth
APPLE_CLIENT_ID="[FROM Apple Developer]"
APPLE_CLIENT_SECRET="[FROM Apple Developer]"

# ================================
# PAYMENTS
# ================================
# Stripe
STRIPE_SECRET_KEY="sk_test_[YOUR_KEY]"
STRIPE_WEBHOOK_SECRET="whsec_[YOUR_WEBHOOK_SECRET]"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_[YOUR_KEY]"

# Paymob (Egypt / MENA)
PAYMOB_API_KEY="[YOUR_PAYMOB_API_KEY]"
PAYMOB_INTEGRATION_ID="[YOUR_INTEGRATION_ID]"
PAYMOB_HMAC_SECRET="[YOUR_HMAC_SECRET]"

# PayPal
PAYPAL_CLIENT_ID="[YOUR_PAYPAL_CLIENT_ID]"
PAYPAL_CLIENT_SECRET="[YOUR_PAYPAL_CLIENT_SECRET]"

# ================================
# STORAGE (Cloudinary)
# ================================
CLOUDINARY_CLOUD_NAME="[YOUR_CLOUD_NAME]"
CLOUDINARY_API_KEY="[YOUR_API_KEY]"
CLOUDINARY_API_SECRET="[YOUR_API_SECRET]"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="[YOUR_CLOUD_NAME]"

# ================================
# EMAIL (Resend / SendGrid)
# ================================
RESEND_API_KEY="re_[YOUR_KEY]"
EMAIL_FROM="hello@noirlabel.com"

# ================================
# ANALYTICS
# ================================
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-[YOUR_ID]"
NEXT_PUBLIC_META_PIXEL_ID="[YOUR_PIXEL_ID]"
NEXT_PUBLIC_TIKTOK_PIXEL_ID="[YOUR_PIXEL_ID]"
NEXT_PUBLIC_CLARITY_PROJECT_ID="[YOUR_PROJECT_ID]"

# ================================
# SITE
# ================================
NEXT_PUBLIC_SITE_URL="https://noirlabel.com"
NEXT_PUBLIC_SITE_NAME="NOIR LABEL"
NODE_ENV="development"
